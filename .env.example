# Supabase — públicas (llegan al navegador, NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — solo servidor. BYPASSEA Row Level Security. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — solo servidor. Envío de correo (notificación interna de solicitudes de crédito).
RESEND_API_KEY=

# Correo interno que recibe la notificación de cada solicitud de crédito.
INTERNAL_NOTIFICATION_EMAIL=
